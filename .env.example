# ── LLM Backend ─────────────────────────────────────────────────
# Choose one backend. The system auto-detects if set to "auto".
# Priority (auto): Gemini > Groq > Ollama > OpenAI > Anthropic > Mock
LLM_BACKEND=auto

# ── Google Gemini (RECOMMENDED — free API) ───────────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Groq (free, ultra-fast — llama3 / mixtral) ──────────────────
# Get key: https://console.groq.com → API Keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Anthropic Claude ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Ollama (local, no API key needed) ────────────────────────────
# Install: https://ollama.com  →  ollama pull mistral
OLLAMA_MODEL=mistral
OLLAMA_URL=http://localhost:11434

# ── Bhagavad Gita API (optional — for full 700-verse download) ───
# Get free key: https://bhagavadgita.io/api
BHAGAVAD_GITA_API_KEY=

# ── System ───────────────────────────────────────────────────────
KG_BACKEND=rdflib
LOG_LEVEL=INFO
